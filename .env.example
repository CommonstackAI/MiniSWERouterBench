# Copy to .env and fill in your own credentials.
# MiniSWERouterBench routes all traffic through OpenRouter (the gateway that
# the locked SWERouterBench pricing in ../SWERouterBench/data/model_pricing.json
# is calibrated against).

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-v1-REPLACE-ME
